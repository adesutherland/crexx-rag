options levelg
import rxfnsb
import rxjson
import rxrag
import pipeline_profile

/*
 * Hybrid history ingestion/extraction profile.
 *
 * CREXX owns the policy gate. The native engine owns storage, de-duplication,
 * traversal, and DOT export. Cheap LLM advisory calls return simple scalars;
 * only the final Gemma extraction call returns candidate proposals for validation.
 */

arg args = .string[]

library = "./history-hybrid.cprag"
profile = "scotland"
mode = "offline"
source_file = ""
source_uri = ""
title = ""
text = ""
limit = 20
offset = 0
stage1 = "auto"
stage1_limit = 0
stage3 = "on"
chunk_size = 1200
overlap = 180
cli = "./cmake-build-debug/crexx-rag"
qwen_base_url = "http://127.0.0.1:8084/v1"
qwen_model = "Qwen/Qwen2.5-3B-Instruct-GGUF:Q4_K_M"
gemma_base_url = "http://127.0.0.1:8080/v1"
gemma_model = "ggml-org/gemma-4-E4B-it-GGUF:Q4_K_M"

ai = 1
do while ai <= args.0
  token = args[ai]
  select
    when token = "--library" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--library needs a value"
      library = args[ai]
    end
    when token = "--profile" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--profile needs a value"
      profile = args[ai]
    end
    when token = "--mode" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--mode needs a value"
      mode = args[ai]
    end
    when token = "--source-file" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--source-file needs a value"
      source_file = args[ai]
    end
    when token = "--source-uri" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--source-uri needs a value"
      source_uri = args[ai]
    end
    when token = "--title" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--title needs a value"
      title = args[ai]
    end
    when token = "--text" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--text needs a value"
      text = args[ai]
    end
    when token = "--limit" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--limit needs a value"
      limit = args[ai]
    end
    when token = "--offset" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--offset needs a value"
      offset = args[ai]
    end
    when token = "--stage1" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--stage1 needs a value"
      stage1 = args[ai]
    end
    when token = "--stage1-limit" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--stage1-limit needs a value"
      stage1_limit = args[ai]
    end
    when token = "--stage3" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--stage3 needs a value"
      stage3 = args[ai]
    end
    when token = "--chunk-size" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--chunk-size needs a value"
      chunk_size = args[ai]
    end
    when token = "--overlap" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--overlap needs a value"
      overlap = args[ai]
    end
    when token = "--cli" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--cli needs a value"
      cli = args[ai]
    end
    when token = "--qwen-base-url" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--qwen-base-url needs a value"
      qwen_base_url = args[ai]
    end
    when token = "--qwen-model" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--qwen-model needs a value"
      qwen_model = args[ai]
    end
    when token = "--gemma-base-url" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--gemma-base-url needs a value"
      gemma_base_url = args[ai]
    end
    when token = "--gemma-model" then do
      ai = ai + 1
      if ai > args.0 then call usage_error "--gemma-model needs a value"
      gemma_model = args[ai]
    end
    when token = "--help" | token = "-h" then call usage
    otherwise call usage_error "unexpected argument: " || token
  end
  ai = ai + 1
end

if profile_supported(profile) = 0 then call usage_error "--profile must be generic, scotland, or athens"
if mode <> "offline" & mode <> "online" then call usage_error "--mode must be offline or online"
if stage1 <> "auto" & stage1 <> "off" & stage1 <> "deterministic" & stage1 <> "llm" then call usage_error "--stage1 must be auto, off, deterministic, or llm"
if stage3 <> "on" & stage3 <> "off" then call usage_error "--stage3 must be on or off"
if text = "" & source_file <> "" then text = read_text_file(source_file)
if text = "" then text = profile_sample_text(profile)
if source_uri = "" then do
  if source_file <> "" then source_uri = source_file
  else source_uri = profile_source_uri(profile)
end
if title = "" then do
  if source_file <> "" then title = source_file
  else title = "Hybrid " || profile || " extraction sample"
end

profile_id = profile_default_id(profile)
ignored = init(library)
call profile_seed_vocabulary library, profile, profile_id
ingest_result = ingest(library, source_uri, title, text, "plain", chunk_size, overlap, '{"profile_id":"' || profile_id || '"}', "external-reference", 0.76, "", "", "")
say ingest_summary(ingest_result)
call run_pipeline library, source_uri, profile, profile_id, mode, offset, limit, stage1, stage1_limit, stage3, cli, qwen_base_url, qwen_model, gemma_base_url, gemma_model
say stats(library)
say exportdot(library, profile_graph_node_filter(profile), profile_relation_filter(profile), 120)

exit 0

usage: procedure
  call lineout "stderr", "usage: hybrid_ingest_extract.crexx [--library PATH] [--profile generic|scotland|athens] [--mode offline|online] [--source-file PATH|--text TEXT] [--offset N] [--limit N] [--stage1 auto|off|deterministic|llm] [--stage1-limit N] [--stage3 on|off] [--cli PATH]"
  exit 0
return

usage_error: procedure
  arg message = .string
  call lineout "stderr", "hybrid_ingest_extract: " || message
  call lineout "stderr", "usage: hybrid_ingest_extract.crexx [--library PATH] [--profile generic|scotland|athens] [--mode offline|online] [--source-file PATH|--text TEXT] [--offset N] [--limit N] [--stage1 auto|off|deterministic|llm] [--stage1-limit N] [--stage3 on|off] [--cli PATH]"
  exit 2
return

ingest_summary: procedure = .string
  arg result = .string
  success = fast_field(result, '"success":', ',')
  source = fast_field(result, '"source_uri":"', '"')
  chunks = fast_field(result, '"chunk_count":', ',')
  profile_id = fast_field(result, '"profile_id":"', '"')
  if source = "" then source = "unknown"
  if success = "" then success = "unknown"
  if chunks = "" then chunks = "unknown"
return "ingest success=" || success || " profile_id=" || profile_id || " source_uri=" || source || " chunks=" || chunks

fast_field: procedure = .string
  arg text = .string, marker = .string, terminator = .string
  start = pos(marker, text)
  if start = 0 then return ""
  start = start + length(marker)
  stop = pos(terminator, text, start)
  if stop = 0 then return strip(substr(text, start))
return strip(substr(text, start, stop - start))

run_pipeline: procedure
  arg library = .string, source_uri = .string, profile = .string, profile_id = .string, mode = .string, offset = .int, limit = .int, stage1 = .string, stage1_limit = .int, stage3 = .string, cli = .string, qwen_base_url = .string, qwen_model = .string, gemma_base_url = .string, gemma_model = .string
  priorities = stage1_priorities(library, source_uri, profile, profile_id, mode, offset, limit, stage1, stage1_limit, cli, qwen_base_url, qwen_model)
  processed = 0
  do while priorities <> "" & (limit < 1 | processed < limit)
    entry = best_priority_entry(priorities)
    if entry = "" then leave
    priorities = remove_priority_entry(priorities, entry)
    parse var entry chunk_id "|" stage1_priority "|" stage1_proper_count "|" stage1_cue_count "|" stage1_known_count "|" stage1_names
    text = chunktextbyid(library, chunk_id)
    processed = processed + 1
    say "stage2 start chunk=" || chunk_id || " order=" || processed || " priority=" || stage1_priority || " proper_names=" || stage1_proper_count || " stage1_known=" || stage1_known_count
    present = mention_matches(library, chunk_id, profile, profile_id, text)
    known_count = count_present(present)
    cue_count = profile_relation_cue_count(profile, text)
    unknown_count = unknown_proper_name_count(text, present)
    type_count = type_diversity(present)
    deterministic_relations = profile_deterministic_relationships(library, chunk_id, profile, profile_id, text, present)
    score = graph_value_score(known_count, cue_count, unknown_count, type_count, deterministic_relations, text)
    route = deterministic_route(score, deterministic_relations)
    route = maybe_model_route(mode, cli, profile, text, present, score, route, qwen_base_url, qwen_model, gemma_base_url, gemma_model)
    say "pipeline chunk=" || chunk_id || " known=" || known_count || " cues=" || cue_count || " unknown_names=" || unknown_count || " type_diversity=" || type_count || " deterministic_edges=" || deterministic_relations || " score=" || score || " route=" || route
    if mode = "online" & route = "gemma-extract" then do
      candidates = gemma_extract(cli, profile, text, gemma_base_url, gemma_model)
      applied = apply_extraction_json(library, chunk_id, profile, profile_id, candidates)
      say "pipeline chunk=" || chunk_id || " gemma_applied=" || applied
    end
  end
  say "pipeline processed=" || processed || " offset=" || offset || " mode=" || mode || " profile=" || profile
  if stage3 = "on" then call stage3_fixup library, profile, profile_id
return

stage1_priorities: procedure = .string
  arg library = .string, source_uri = .string, profile = .string, profile_id = .string, mode = .string, offset = .int, limit = .int, stage1 = .string, stage1_limit = .int, cli = .string, qwen_base_url = .string, qwen_model = .string
  effective_stage1 = stage1
  if effective_stage1 = "auto" then do
    if mode = "online" then effective_stage1 = "llm"
    else effective_stage1 = "deterministic"
  end
  if effective_stage1 = "off" then effective_stage1 = "deterministic"
  scan_limit = stage1_limit
  if scan_limit = 0 then scan_limit = limit
  ids = chunkids(library, source_uri)
  skipped = 0
  scanned = 0
  priorities = ""
  census_clear = clearcandidatecensus(library, profile_id, source_uri)
  say "stage1 start mode=" || effective_stage1 || " offset=" || offset || " scan_limit=" || scan_limit || " profile=" || profile
  do while ids <> ""
    parse var ids chunk_id "," ids
    if skipped < offset then do
      skipped = skipped + 1
      iterate
    end
    if scan_limit > 0 & scanned >= scan_limit then leave
    text = chunktextbyid(library, chunk_id)
    scanned = scanned + 1
    names = ""
    model_names = ""
    deterministic_names = proper_names(text)
    if effective_stage1 = "llm" then do
      model_names = normalize_name_list(llm_advice(cli, "proper-nouns", profile, "", text, qwen_base_url, qwen_model))
      if model_names <> "" then names = model_names
      else names = deterministic_names
    end
    else names = normalize_name_list(deterministic_names)
    proper_count = name_list_count(names)
    if proper_count = 0 & deterministic_names <> "" then do
      names = deterministic_names
      proper_count = name_list_count(names)
      if effective_stage1 = "llm" then say "stage1 llm fallback chunk=" || chunk_id || " reason=no-proper-nouns"
    end
    cue_count = profile_relation_cue_count(profile, text)
    matches = matchconcepts(library, text, profile_match_node_filter(profile))
    known_count = jsoncount(matches, "matches")
    priority = stage1_priority(proper_count, cue_count, known_count, text)
    safe_names = sanitize_field(names)
    priorities = priorities || chunk_id || "|" || priority || "|" || proper_count || "|" || cue_count || "|" || known_count || "|" || safe_names || ";"
    call persist_stage1_names library, profile_id, source_uri, chunk_id, names, priority, proper_count, known_count, cue_count, effective_stage1
    say "stage1 chunk=" || chunk_id || " scanned=" || scanned || " priority=" || priority || " proper_names=" || proper_count || " known=" || known_count || " cues=" || cue_count || " names=" || safe_names
  end
  say "stage1 complete scanned=" || scanned || " candidates=" || entry_count(priorities)
return priorities

persist_stage1_names: procedure
  arg library = .string, profile_id = .string, source_uri = .string, chunk_id = .int, names = .string, priority = .int, proper_count = .int, known_count = .int, cue_count = .int, extractor = .string
  rest = names
  do while rest <> ""
    parse var rest name "|" rest
    name = clean_name_candidate(name)
    if name = "" then iterate
    normalized = normalize_candidate_key(name)
    metadata_json = '{"source":"stage1-census"}'
    ignored = addcandidatemention(library, profile_id, source_uri, chunk_id, name, normalized, priority, proper_count, known_count, cue_count, "stage1", extractor, metadata_json)
  end
return

normalize_candidate_key: procedure = .string
  arg value = .string
  value = clean_name_candidate(value)
return upper(strip(value))

stage1_priority: procedure = .int
  arg proper_count = .int, cue_count = .int, known_count = .int, text = .string
  priority = (2 * proper_count) + (5 * cue_count) + (6 * known_count)
  if contains_any(text, "called|anciently|formerly|known as|descended|sons of|sprung from") = 1 then priority = priority + 6
return priority

proper_names: procedure = .string
  arg text = .string
  out = ""
  phrase = ""
  do wi = 1 to words(text)
    token = clean_token(word(text, wi))
    if token <> "" & is_capitalized(token) = 1 & is_stop_name(token) = 0 then do
      if phrase = "" then phrase = token
      else phrase = phrase || " " || token
    end
    else do
      if phrase <> "" then do
        out = append_name(out, phrase)
        phrase = ""
      end
    end
  end
  if phrase <> "" then out = append_name(out, phrase)
return out

normalize_name_list: procedure = .string
  arg names = .string
  out = ""
  token = ""
  do i = 1 to length(names)
    ch = substr(names, i, 1)
    if ch = "," | ch = "|" | ch = ";" | ch = "0a"x | ch = "0d"x then do
      out = append_name(out, token)
      token = ""
    end
    else token = token || ch
  end
  out = append_name(out, token)
return out

append_name: procedure = .string
  arg names = .string, value = .string
  value = clean_name_candidate(value)
  if value = "" then return names
  if is_stop_name(value) = 1 | is_stage1_generic_name(value) = 1 then return names
  if list_has_value(names, value) = 1 then return names
  if names = "" then return value
return names || "|" || value

clean_name_candidate: procedure = .string
  arg value = .string
  value = strip(value)
  if upper(value) = "NONE" then return ""
  do while value <> "" & is_candidate_edge_char(left(value, 1)) = 0
    value = substr(value, 2)
  end
  do while value <> "" & is_candidate_edge_char(right(value, 1)) = 0
    value = left(value, length(value) - 1)
  end
return strip(value)

is_candidate_edge_char: procedure = .int
  arg ch = .string
  if ch >= "A" & ch <= "Z" then return 1
  if ch >= "a" & ch <= "z" then return 1
  if ch >= "0" & ch <= "9" then return 1
  if ch = "'" then return 1
return 0

list_has_value: procedure = .int
  arg values = .string, value = .string
  rest = values
  do while rest <> ""
    parse var rest item "|" rest
    if upper(strip(item)) = upper(strip(value)) then return 1
  end
return 0

name_list_count: procedure = .int
  arg names = .string
  count = 0
  token = ""
  do i = 1 to length(names)
    ch = substr(names, i, 1)
    if ch = "," | ch = "|" | ch = ";" | ch = "0a"x | ch = "0d"x then do
      if strip(token) <> "" then count = count + 1
      token = ""
    end
    else token = token || ch
  end
  if strip(token) <> "" then count = count + 1
return count

sanitize_field: procedure = .string
  arg value = .string
  out = ""
  last_was_separator = 0
  do i = 1 to length(value)
    ch = substr(value, i, 1)
    if ch = "|" | ch = ";" | ch = "0a"x | ch = "0d"x | ch = "09"x then do
      if last_was_separator = 0 & out <> "" then out = out || ", "
      last_was_separator = 1
    end
    else do
      out = out || ch
      last_was_separator = 0
    end
    if length(out) >= 220 then leave
  end
return strip(out)

best_priority_entry: procedure = .string
  arg entries = .string
  best = ""
  best_priority = -999999
  rest = entries
  do while rest <> ""
    parse var rest entry ";" rest
    if entry = "" then iterate
    parse var entry chunk_id "|" priority "|" remaining
    if priority > best_priority then do
      best_priority = priority
      best = entry
    end
  end
return best

remove_priority_entry: procedure = .string
  arg entries = .string, remove = .string
  out = ""
  removed = 0
  rest = entries
  do while rest <> ""
    parse var rest entry ";" rest
    if entry = "" then iterate
    if removed = 0 & entry = remove then removed = 1
    else out = out || entry || ";"
  end
return out

entry_count: procedure = .int
  arg entries = .string
  count = 0
  rest = entries
  do while rest <> ""
    parse var rest entry ";" rest
    if entry <> "" then count = count + 1
  end
return count

stage3_fixup: procedure
  arg library = .string, profile = .string, profile_id = .string
  ambiguities = listconcepts(library, "ambiguity")
  ambiguity_count = jsoncount(ambiguities, "concepts")
  say "stage3 start profile=" || profile || " ambiguity_nodes=" || ambiguity_count
  do i = 1 to ambiguity_count
    id = jsonget(ambiguities, "concepts." || i || ".id")
    label = jsonget(ambiguities, "concepts." || i || ".label")
    say "stage3 ambiguity id=" || id || " label=" || label || " action=revisit-with-context"
  end
  say "stage3 complete ambiguity_nodes=" || ambiguity_count
return

maybe_model_route: procedure = .string
  arg mode = .string, cli = .string, profile = .string, text = .string, present = .string, score = .int, route = .string, qwen_base_url = .string, qwen_model = .string, gemma_base_url = .string, gemma_model = .string
  if mode <> "online" then return route
  if route = "deterministic" & score < 18 then return route
  context = "known=" || present || " score=" || score || " deterministic_route=" || route
  qwen_route = llm_advice(cli, "route", profile, context, text, qwen_base_url, qwen_model)
  qwen_value = llm_advice(cli, "value", profile, context, text, qwen_base_url, qwen_model)
  qwen_complexity = llm_advice(cli, "complexity", profile, context, text, qwen_base_url, qwen_model)
  say "pipeline qwen route=" || qwen_route || " value=" || qwen_value || " complexity=" || qwen_complexity
  if qwen_route = "skip" & score < 10 then return "skip"
  if qwen_route = "deterministic" & route = "deterministic" then return route
  if qwen_route = "medium" & qwen_complexity <> "high" then return "gemma-advice"
  if qwen_route = "gemma-advice" | qwen_route = "gemma-extract" | qwen_value >= 4 | qwen_complexity = "high" | route = "gemma-extract" then do
    gemma_route = llm_advice(cli, "route", profile, context || " qwen_route=" || qwen_route || " qwen_value=" || qwen_value || " qwen_complexity=" || qwen_complexity, text, gemma_base_url, gemma_model)
    say "pipeline gemma_advice route=" || gemma_route
    if gemma_route = "gemma-extract" then return "gemma-extract"
    if gemma_route = "deterministic" then return route
    return gemma_route
  end
return route

llm_advice: procedure = .string
  arg cli = .string, task = .string, profile = .string, context = .string, text = .string, base_url = .string, model = .string
  command = cli || " advise-llama-server --stdin --task " || command_quote(task) || " --profile " || command_quote(profile) || " --context " || command_quote(context) || " --base-url " || command_quote(base_url) || " --model " || command_quote(model) || " --temperature 0 --max-tokens 64"
  answer = run_command_stdout_input(command, text)
  answer = first_line(answer)
  if answer = "" then return "skip"
return answer

gemma_extract: procedure = .string
  arg cli = .string, profile = .string, text = .string, base_url = .string, model = .string
  command = cli || " extract-llama-server --stdin --profile " || command_quote(profile) || " --base-url " || command_quote(base_url) || " --model " || command_quote(model) || " --temperature 0.1 --max-tokens 2048"
return run_command_stdout_input(command, text)

apply_extraction_json: procedure = .int
  arg library = .string, chunk_id = .string, profile = .string, profile_id = .string, candidates = .string
  if jsonvalid(candidates) = 0 then return 0
  applied = 0
  nodes = jsoncount(candidates, "nodes")
  do i = 1 to nodes
    id = jsonget(candidates, "nodes." || i || ".id")
    node_type = jsonget(candidates, "nodes." || i || ".node_type")
    label = jsonget(candidates, "nodes." || i || ".label")
    confidence = jsonget(candidates, "nodes." || i || ".confidence")
    evidence = jsonget(candidates, "nodes." || i || ".evidence")
    aliases = aliases_from_json(candidates, "nodes." || i || ".aliases", label)
    if id <> "" & label <> "" & profile_allowed_node_type(profile, node_type) = 1 & confidence_at_least(confidence, 0.45) = 1 then do
      call add_evidence_chunk library, chunk_id, profile_id
      ignored = addentitytyped(library, id, node_type, label, "Accepted from Gemma extraction candidate.", metadata(profile_id, chunk_id, "gemma-extraction", evidence, aliases))
      ignored = addedgetyped(library, id, evidence_id(chunk_id), "mentioned-in", "Gemma candidate mentioned in source chunk.", confidence_or_default(confidence, 0.62), metadata(profile_id, chunk_id, "gemma-extraction", evidence, ""))
      applied = applied + 1
    end
  end
  relationships = jsoncount(candidates, "relationships")
  do i = 1 to relationships
    source_id = jsonget(candidates, "relationships." || i || ".source_id")
    target_id = jsonget(candidates, "relationships." || i || ".target_id")
    relationship_type = jsonget(candidates, "relationships." || i || ".relationship_type")
    label = jsonget(candidates, "relationships." || i || ".label")
    confidence = jsonget(candidates, "relationships." || i || ".confidence")
    evidence = jsonget(candidates, "relationships." || i || ".evidence")
    if source_id <> "" & target_id <> "" & profile_allowed_relation_type(profile, relationship_type) = 1 & confidence_at_least(confidence, 0.52) = 1 then do
      ignored = addedgetyped(library, source_id, target_id, relationship_type, label, confidence_or_default(confidence, 0.58), metadata(profile_id, chunk_id, "gemma-extraction", evidence, ""))
      applied = applied + 1
    end
  end
return applied

mention_matches: procedure = .string
  arg library = .string, chunk_id = .string, profile = .string, profile_id = .string, text = .string
  matches = matchconcepts(library, text, profile_match_node_filter(profile))
  count = jsoncount(matches, "matches")
  present = ""
  ambiguity_seen = ""
  do i = 1 to count
    id = jsonget(matches, "matches." || i || ".id")
    node_type = jsonget(matches, "matches." || i || ".node_type")
    label = jsonget(matches, "matches." || i || ".label")
    matched_alias = jsonget(matches, "matches." || i || ".matched_alias")
    if id <> "" then do
      if alias_match_count(matches, count, matched_alias) > 1 then do
        if contains_any(matched_alias, ambiguity_seen) = 0 then do
          ambiguity_seen = append_pipe(ambiguity_seen, matched_alias)
          call add_ambiguity_node library, chunk_id, profile_id, matched_alias, matches, count
        end
      end
      else do
        if has_concept(present, id) = 0 then do
          call add_evidence_chunk library, chunk_id, profile_id
          ignored = addedgetyped(library, id, evidence_id(chunk_id), "mentioned-in", "Known concept mention: " || matched_alias, 0.88, metadata(profile_id, chunk_id, "known-concept-match", matched_alias, ""))
          present = present || id || "|" || node_type || "|" || label || ";"
        end
      end
    end
  end
return present

alias_match_count: procedure = .int
  arg matches = .string, count = .int, alias = .string
  found = 0
  do i = 1 to count
    matched_alias = jsonget(matches, "matches." || i || ".matched_alias")
    if matched_alias = alias then found = found + 1
  end
return found

add_ambiguity_node: procedure
  arg library = .string, chunk_id = .string, profile_id = .string, alias = .string, matches = .string, count = .int
  ambiguity_id = "ambiguity:chunk:" || chunk_id || ":" || slug(alias)
  candidate_ids = ""
  call add_evidence_chunk library, chunk_id, profile_id
  ignored = addentitytyped(library, ambiguity_id, "ambiguity", "Ambiguous mention: " || alias, "Mention matched multiple profile concepts and requires Stage 3 disambiguation.", metadata(profile_id, chunk_id, "ambiguity-detection", "pending", ""))
  ignored = addedgetyped(library, ambiguity_id, evidence_id(chunk_id), "mentioned-in", "Ambiguous mention found in source chunk.", 0.5, metadata(profile_id, chunk_id, "ambiguity-detection", alias, ""))
  do i = 1 to count
    id = jsonget(matches, "matches." || i || ".id")
    node_type = jsonget(matches, "matches." || i || ".node_type")
    label = jsonget(matches, "matches." || i || ".label")
    matched_alias = jsonget(matches, "matches." || i || ".matched_alias")
    if matched_alias = alias & id <> "" then do
      candidate_ids = append_pipe(candidate_ids, id)
      ignored = addedgetyped(library, id, ambiguity_id, "candidate-for", "Candidate interpretation for ambiguous mention " || alias || ".", 0.4, metadata(profile_id, chunk_id, "ambiguity-candidate", alias || " -> " || label || " (" || node_type || ")", ""))
    end
  end
  ignored = addentitytyped(library, ambiguity_id, "ambiguity", "Ambiguous mention: " || alias, "Mention matched multiple profile concepts and requires Stage 3 disambiguation.", metadata(profile_id, chunk_id, "ambiguity-detection", "candidates=" || candidate_ids, ""))
return

graph_value_score: procedure = .int
  arg known = .int, cues = .int, unknown = .int, type_count = .int, deterministic_relations = .int, text = .string
  score = (3 * known) + (4 * cues) + (2 * unknown) + (5 * type_count) + (6 * deterministic_relations)
  if contains_any(text, "called|anciently|formerly|alias|known as|descended|sons of|sprung from") = 1 then score = score + 5
  if known = 0 & cues = 0 then score = score - 5
return score

deterministic_route: procedure = .string
  arg score = .int, deterministic_relations = .int
  if deterministic_relations > 0 & score >= 8 then return "deterministic"
  if score >= 22 then return "gemma-extract"
  if score >= 14 then return "gemma-advice"
  if score >= 6 then return "medium"
return "skip"

unknown_proper_name_count: procedure = .int
  arg text = .string, present = .string
  count = 0
  do wi = 1 to words(text)
    token = clean_token(word(text, wi))
    if token <> "" & is_capitalized(token) = 1 & is_stop_name(token) = 0 then do
      if present_contains_label(present, token) = 0 then count = count + 1
    end
  end
return count

type_diversity: procedure = .int
  arg present = .string
  seen = ""
  count = 0
  rest = present
  do while rest <> ""
    parse var rest entry ";" rest
    parse var entry id "|" node_type "|" label
    if node_type <> "" & contains_any(node_type, seen) = 0 then do
      seen = append_pipe(seen, node_type)
      count = count + 1
    end
  end
return count

count_present: procedure = .int
  arg present = .string
  count = 0
  rest = present
  do while rest <> ""
    parse var rest entry ";" rest
    if entry <> "" then count = count + 1
  end
return count

has_concept: procedure = .int
  arg present = .string, id = .string
  rest = present
  do while rest <> ""
    parse var rest entry ";" rest
    parse var entry entry_id "|" entry_type "|" entry_label
    if entry_id = id then return 1
  end
return 0

present_contains_label: procedure = .int
  arg present = .string, token = .string
  rest = present
  do while rest <> ""
    parse var rest entry ";" rest
    parse var entry entry_id "|" entry_type "|" entry_label
    if contains(entry_label, token) = 1 then return 1
  end
return 0

concept_label: procedure = .string
  arg present = .string, id = .string
  rest = present
  do while rest <> ""
    parse var rest entry ";" rest
    parse var entry entry_id "|" entry_type "|" entry_label
    if entry_id = id then return entry_label
  end
return id

add_evidence_chunk: procedure
  arg library = .string, chunk_id = .string, profile_id = .string
  ignored = addentitytyped(library, evidence_id(chunk_id), "evidence-chunk", "Chunk " || chunk_id, "Source chunk used as extraction evidence.", metadata(profile_id, chunk_id, "evidence", "source chunk", ""))
return

metadata: procedure = .string
  arg profile_id = .string, chunk_id = .string, extractor = .string, evidence = .string, aliases = .string
  keys = .string[]
  values = .string[]
  keys[1] = "profile_id"; values[1] = jsonquote(profile_id)
  keys[2] = "chunk_id"; values[2] = chunk_id
  keys[3] = "extractor"; values[3] = jsonquote(extractor)
  keys[4] = "evidence"; values[4] = jsonquote(evidence)
  if aliases <> "" then do
    keys[5] = "aliases"; values[5] = jsonquote(aliases)
  end
return jsonobject(keys, values)

aliases_from_json: procedure = .string
  arg json = .string, path = .string, fallback = .string
  count = jsoncount(json, path)
  out = ""
  do i = 1 to count
    value = jsonget(json, path || "." || i)
    if value <> "" then out = append_pipe(out, value)
  end
  if out = "" then out = fallback
return out

confidence_at_least: procedure = .int
  arg value = .string, threshold = .float
  if value = "" then return 1
  if value >= threshold then return 1
return 0

confidence_or_default: procedure = .float
  arg value = .string, fallback = .float
  if value = "" then return fallback
return value

read_text_file: procedure = .string
  arg path = .string
  command = "cat " || command_quote(path)
return run_command_stdout(command)

run_command_stdout: procedure = .string
  arg command = .string
  out = .string[]
  err = .string[]
  call arraydrop out
  call arraydrop err
  address command command output out error err
  command_rc = rc
  if command_rc <> 0 then do
    call lineout "stderr", "hybrid_ingest_extract: command failed rc=" || command_rc || " command=" || command
    call write_stem "stderr", err
    return ""
  end
return join_lines(out)

run_command_stdout_input: procedure = .string
  arg command = .string, text = .string
  input_lines = .string[]
  line = ""
  line_index = 1
  do i = 1 to length(text)
    ch = substr(text, i, 1)
    if ch = "0a"x then do
      input_lines[line_index] = line
      line_index = line_index + 1
      line = ""
    end
    else if ch <> "0d"x then line = line || ch
  end
  input_lines[line_index] = line
  out = .string[]
  err = .string[]
  call arraydrop out
  call arraydrop err
  address command command input input_lines output out error err
  command_rc = rc
  if command_rc <> 0 then do
    call lineout "stderr", "hybrid_ingest_extract: command failed rc=" || command_rc || " command=" || command
    call write_stem "stderr", err
    return ""
  end
return join_lines(out)

write_stem: procedure
  arg stream = .string, values = .string[]
  do i = 1 to values.0
    call lineout stream, values[i]
  end
return

join_lines: procedure = .string
  arg values = .string[]
  out = ""
  do i = 1 to values.0
    if i > 1 then out = out || "0a"x
    out = out || values[i]
  end
return out

first_line: procedure = .string
  arg text = .string
  newline = pos("0a"x, text)
  if newline = 0 then return strip(text)
  line = substr(text, 1, newline - 1)
return strip(line)

command_quote: procedure = .string
  arg value = .string
return shell_quote(value)

shell_quote: procedure = .string
  arg value = .string
  quote = "'"
  out = quote
  do i = 1 to length(value)
    ch = substr(value, i, 1)
    if ch = quote then out = out || quote || "\" || quote || quote
    else out = out || ch
  end
return out || quote

append_pipe: procedure = .string
  arg text = .string, value = .string
  if value = "" then return text
  if text = "" then return value
return text || "|" || value

contains_any: procedure = .int
  arg text = .string, needles = .string
  rest = needles
  do while rest <> ""
    parse var rest needle "|" rest
    if needle <> "" then do
      if contains(text, needle) = 1 then return 1
    end
  end
return 0

contains: procedure = .int
  arg text = .string, needle = .string
  if pos(upper(needle), upper(text)) > 0 then return 1
return 0

clean_token: procedure = .string
  arg token = .string
  do while token <> "" & is_name_char(left(token, 1)) = 0
    token = substr(token, 2)
  end
  do while token <> "" & is_name_char(right(token, 1)) = 0
    token = left(token, length(token) - 1)
  end
return token

is_name_char: procedure = .int
  arg ch = .string
  if ch >= "A" & ch <= "Z" then return 1
  if ch >= "a" & ch <= "z" then return 1
  if ch = "-" | ch = "'" then return 1
return 0

is_capitalized: procedure = .int
  arg token = .string
  if token = "" then return 0
  ch = left(token, 1)
  if ch >= "A" & ch <= "Z" then return 1
return 0

is_stop_name: procedure = .int
  arg token = .string
  clean = strip(token)
  if clean = "" then return 1
  if length(clean) = 1 then return 1
  stops = "The|A|An|And|But|Or|In|On|Of|To|For|From|By|With|As|At|This|That|These|Those|It|Its|He|She|They|We|I|His|Her|Their|When|Where|While|After|Before|Since|There|Here|Yet|One|What|Into|Down|Every|Each|Such|Chapter|Book|Volume|Part|Section|Appendix|No|Mr|Mrs|Dr|Sir|Lord|Lady|Clan|Clans|Chief|Chiefs|King|Kings|Queen|Queens"
  rest = stops
  do while rest <> ""
    parse var rest stop "|" rest
    if upper(clean) = upper(stop) then return 1
  end
return 0

is_stage1_generic_name: procedure = .int
  arg value = .string
  clean = upper(strip(value))
  generics = "SCOTLAND|SCOTTISH|SCOTS|HIGHLAND|HIGHLANDS|HIGHLANDERS|GAELIC|CELTIC|LOWLANDS|GOVERNMENT|ACCORDING|ILLUSTRATION|ILLUSTRATIONS|FOOTNOTE|FOOTNOTES|PREFACE|TITLE|CONTENTS|LISTS|INDEX|TEXT|MANY|GENERAL HISTORY|GREATER|SECOND|ORIGIN|DETAILED ACCOUNT|EACH SEPARATE|MOST RECENT INVESTIGATIONS ILLUSTRATIONS BESIDES"
  rest = generics
  do while rest <> ""
    parse var rest generic "|" rest
    if clean = generic then return 1
  end
return 0

slug: procedure = .string
  arg value = .string
  out = ""
  last_was_dash = 0
  do i = 1 to length(value)
    ch = substr(value, i, 1)
    if is_slug_char(ch) = 1 then do
      out = out || ch
      last_was_dash = 0
    end
    else do
      if out <> "" & last_was_dash = 0 then do
        out = out || "-"
        last_was_dash = 1
      end
    end
  end
  do while right(out, 1) = "-"
    out = left(out, length(out) - 1)
  end
  if out = "" then out = "unknown"
return out

is_slug_char: procedure = .int
  arg ch = .string
  if ch >= "A" & ch <= "Z" then return 1
  if ch >= "a" & ch <= "z" then return 1
  if ch >= "0" & ch <= "9" then return 1
return 0

evidence_id: procedure = .string
  arg chunk_id = .string
return "evidence:chunk:" || chunk_id
